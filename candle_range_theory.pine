//@version=5
indicator("Candle Range Theory (CRT) Engine", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// =========================================================================
// INPUTS & CONFIGURATION
// =========================================================================

// Timeframe Settings
htfTimeframe  = input.timeframe("240", "HTF Range Timeframe", group="Timeframe Settings", tooltip="The timeframe of the candle that defines the trading range (e.g., 240 for 4-Hour, 1D for Daily)")

// Sweep & Confirmation Settings
slBufferTicks = input.int(5, "Stop Loss Buffer (Ticks/Pips)", minval=0, group="Strategy Settings", tooltip="Additional buffer added to the sweep extreme to protect stop loss")
useAtrFilter  = input.bool(true, "Use ATR for Stop Loss Buffer", group="Strategy Settings")
atrPeriod     = input.int(14, "ATR Period for SL Buffer", minval=1, group="Strategy Settings")
atrMultiplier = input.float(0.2, "ATR Multiplier", minval=0.0, step=0.1, group="Strategy Settings", tooltip="SL Buffer = ATR * Multiplier")

// Visual Styling Options
color_range_high  = input.color(#FFD600, "Range High Line", group="Style & Colors")
color_range_low   = input.color(#FFD600, "Range Low Line", group="Style & Colors")
color_range_mid   = input.color(#78909C, "Range Midpoint (50%)", group="Style & Colors")
color_long_sig    = input.color(#00E676, "Bullish Reversal (Long)", group="Style & Colors")
color_short_sig   = input.color(#FF1744, "Bearish Reversal (Short)", group="Style & Colors")
color_dashboard   = input.color(#1E222D, "Dashboard Background", group="Style & Colors")

// Dashboard & Visual Toggles
showRangeLines    = input.bool(true, "Show HTF Range Boundaries on Chart", group="Visual Options")
showTradeVisuals  = input.bool(true, "Draw Risk/Reward Setup Box", group="Visual Options")
showDashboard     = input.bool(true, "Show Range Status Dashboard", group="Visual Options")
dashPosition      = input.string("top_right", "Dashboard Position", options=["top_right", "bottom_right", "top_left", "bottom_left"], group="Visual Options")

// =========================================================================
// MULTI-TIMEFRAME DATA FETCHING & RANGE SETUP
// =========================================================================

// Fetch the previous completed HTF candle data to prevent repainting in live market
htf_high  = request.security(syminfo.tickerid, htfTimeframe, high[1], barmerge.gaps_off, barmerge.lookahead_off)
htf_low   = request.security(syminfo.tickerid, htfTimeframe, low[1], barmerge.gaps_off, barmerge.lookahead_off)
htf_close = request.security(syminfo.tickerid, htfTimeframe, close[1], barmerge.gaps_off, barmerge.lookahead_off)
htf_time  = request.security(syminfo.tickerid, htfTimeframe, time[1], barmerge.gaps_off, barmerge.lookahead_off)

// Detect HTF candle changes
htfChanged = ta.change(htf_time) != 0

// Persistent range variables
var float rangeHigh = na
var float rangeLow  = na
var float rangeMid  = na

if htfChanged or na(rangeHigh)
    rangeHigh := htf_high
    rangeLow  := htf_low
    rangeMid  := (htf_high + htf_low) / 2

// Plot HTF Boundaries (using a color-alternating hack to draw the midpoint as a dashed line in Pine Script v5)
plot(showRangeLines ? rangeHigh : na, color=color_range_high, title="HTF Range High", linewidth=2)
plot(showRangeLines ? rangeLow : na, color=color_range_low, title="HTF Range Low", linewidth=2)
plot(showRangeLines ? rangeMid : na, color = bar_index % 2 == 0 ? color_range_mid : color.new(color_range_mid, 100), title="HTF Range Midpoint (50%)", linewidth=1)

// =========================================================================
// SWEEP DETECTION & SIGNAL GENERATION
// =========================================================================

// Persistent sweep tracking states
var bool bslSwept = false // Buy-Side Liquidity Swept (Range High)
var bool sslSwept = false // Sell-Side Liquidity Swept (Range Low)
var float sweepHighPrice = na
var float sweepLowPrice  = na

// Reset sweeps and extreme prices on new HTF candle
if htfChanged
    bslSwept := false
    sslSwept := false
    sweepHighPrice := na
    sweepLowPrice  := na

// Monitor sweeps on current timeframe
if not bslSwept and high > rangeHigh
    bslSwept := true
    sweepHighPrice := high
else if bslSwept and high > sweepHighPrice
    sweepHighPrice := high // Update extreme high of sweep

if not sslSwept and low < rangeLow
    sslSwept := true
    sweepLowPrice := low
else if sslSwept and low < sweepLowPrice
    sweepLowPrice := low // Update extreme low of sweep

// Signal Conditions: Sweep followed by close back inside the HTF range (single or multi-bar)
longSignal  = sslSwept and close > rangeLow
shortSignal = bslSwept and close < rangeHigh

// Reset sweep flag once triggered to prevent duplicate entries on the same sweep
if longSignal
    sslSwept := false
if shortSignal
    bslSwept := false

// ATR for dynamic risk buffer
atrVal = ta.atr(atrPeriod)
slBuffer = useAtrFilter ? (atrVal * atrMultiplier) : (syminfo.mintick * slBufferTicks)

// =========================================================================
// TRADE SUGGESTION & RISK VISUALIZER & DYNAMIC ALERTS
// =========================================================================

var box setupRiskBox   = na
var box setupRewardBox = na
var line setupTp1Line  = na

if longSignal
    float entryPrice = close
    float stopLoss   = (na(sweepLowPrice) ? low : sweepLowPrice) - slBuffer
    float takeProfit2 = rangeHigh
    float takeProfit1 = rangeMid
    
    if showTradeVisuals
        box.delete(setupRiskBox)
        box.delete(setupRewardBox)
        line.delete(setupTp1Line)
        setupRiskBox := box.new(left=bar_index, top=entryPrice, right=bar_index + 20, bottom=stopLoss,
                                 border_color=color.new(color_short_sig, 30), bgcolor=color.new(color_short_sig, 92))
        setupRewardBox := box.new(left=bar_index, top=takeProfit2, right=bar_index + 20, bottom=entryPrice,
                                  border_color=color.new(color_long_sig, 30), bgcolor=color.new(color_long_sig, 92))
        setupTp1Line := line.new(bar_index, takeProfit1, bar_index + 20, takeProfit1, color=color_range_mid, style=line.style_dashed, width=1)
    
    // Webhook-friendly dynamic alert triggering on bar close
    alert("CRT BUY: " + syminfo.ticker + " | Entry: " + str.tostring(entryPrice) + " | SL: " + str.tostring(stopLoss) + " | TP1 (50%): " + str.tostring(takeProfit1) + " | TP2 (100%): " + str.tostring(takeProfit2), alert.freq_once_per_bar_close)
    
if shortSignal
    float entryPrice = close
    float stopLoss   = (na(sweepHighPrice) ? high : sweepHighPrice) + slBuffer
    float takeProfit2 = rangeLow
    float takeProfit1 = rangeMid
    
    if showTradeVisuals
        box.delete(setupRiskBox)
        box.delete(setupRewardBox)
        line.delete(setupTp1Line)
        setupRiskBox := box.new(left=bar_index, top=stopLoss, right=bar_index + 20, bottom=entryPrice,
                                 border_color=color.new(color_short_sig, 30), bgcolor=color.new(color_short_sig, 92))
        setupRewardBox := box.new(left=bar_index, top=entryPrice, right=bar_index + 20, bottom=takeProfit2,
                                  border_color=color.new(color_long_sig, 30), bgcolor=color.new(color_long_sig, 92))
        setupTp1Line := line.new(bar_index, takeProfit1, bar_index + 20, takeProfit1, color=color_range_mid, style=line.style_dashed, width=1)

    // Webhook-friendly dynamic alert triggering on bar close
    alert("CRT SELL: " + syminfo.ticker + " | Entry: " + str.tostring(entryPrice) + " | SL: " + str.tostring(stopLoss) + " | TP1 (50%): " + str.tostring(takeProfit1) + " | TP2 (100%): " + str.tostring(takeProfit2), alert.freq_once_per_bar_close)

// Plot Shapes on chart when entry signals trigger
plotshape(longSignal, title="CRT Long Signal", style=shape.triangleup, location=location.belowbar, color=color_long_sig, size=size.small, text="CRT BUY")
plotshape(shortSignal, title="CRT Short Signal", style=shape.triangledown, location=location.abovebar, color=color_short_sig, size=size.small, text="CRT SELL")

// =========================================================================
// INFORMATION DASHBOARD
// =========================================================================

var table dashTable = na
if showDashboard and barstate.islast
    tablePos = dashPosition == "top_right" ? position.top_right :
               dashPosition == "bottom_right" ? position.bottom_right :
               dashPosition == "top_left" ? position.top_left : position.bottom_left
               
    dashTable := table.new(tablePos, 2, 6, bgcolor=color_dashboard, border_color=color.new(color_range_mid, 70), border_width=1)
    
    // Header
    table.cell(dashTable, 0, 0, "CRT Engine", text_color=color.white, bgcolor=color.new(color_range_mid, 20), text_size=size.small, width=14)
    table.cell(dashTable, 1, 0, "HTF: " + htfTimeframe, text_color=color.white, bgcolor=color.new(color_range_mid, 20), text_size=size.small, width=14)
    
    // Status
    table.cell(dashTable, 0, 1, "Buy-Side Swept (High)", text_color=color.gray, text_size=size.small)
    table.cell(dashTable, 1, 1, bslSwept ? "Yes (Awaiting Re-entry)" : "No", text_color=bslSwept ? color_short_sig : color.white, text_size=size.small)
    
    table.cell(dashTable, 0, 2, "Sell-Side Swept (Low)", text_color=color.gray, text_size=size.small)
    table.cell(dashTable, 1, 2, sslSwept ? "Yes (Awaiting Re-entry)" : "No", text_color=sslSwept ? color_long_sig : color.white, text_size=size.small)
    
    // Pricing Zone
    string pricingZone = "Equilibrium"
    color zoneCol = color_range_mid
    if close > rangeMid
        pricingZone := "Premium (Sell Zone)"
        zoneCol := color_short_sig
    else if close < rangeMid
        pricingZone := "Discount (Buy Zone)"
        zoneCol := color_long_sig
        
    table.cell(dashTable, 0, 3, "Pricing Zone", text_color=color.gray, text_size=size.small)
    table.cell(dashTable, 1, 3, pricingZone, text_color=zoneCol, text_size=size.small)
    
    // HTF Range Height
    rangeHeight = rangeHigh - rangeLow
    table.cell(dashTable, 0, 4, "Range Size", text_color=color.gray, text_size=size.small)
    table.cell(dashTable, 1, 4, str.tostring(rangeHeight, "#.#####"), text_color=color.white, text_size=size.small)
    
    // Last Signal
    var string lastSig = "None"
    var color sigCol = color.white
    if longSignal
        lastSig := "BUY"
        sigCol := color_long_sig
    else if shortSignal
        lastSig := "SELL"
        sigCol := color_short_sig
        
    table.cell(dashTable, 0, 5, "Last Trigger", text_color=color.gray, text_size=size.small)
    table.cell(dashTable, 1, 5, lastSig, text_color=sigCol, text_size=size.small)

// =========================================================================
// WEBHOOK-COMPATIBLE LIVE ALERTS
// =========================================================================

// These conditions can be set up in TradingView to send alerts to live order execution platforms.
alertcondition(longSignal, title="CRT Buy Alert", 
               message="CRT Buy Signal Triggered on {{ticker}}! Entry: {{close}}, TP1 (Mid): {{plot_2}}, TP2 (High): {{plot_0}} (SL is dynamic, use the dynamic alert message)")

alertcondition(shortSignal, title="CRT Sell Alert", 
               message="CRT Sell Signal Triggered on {{ticker}}! Entry: {{close}}, TP1 (Mid): {{plot_2}}, TP2 (Low): {{plot_1}} (SL is dynamic, use the dynamic alert message)")
